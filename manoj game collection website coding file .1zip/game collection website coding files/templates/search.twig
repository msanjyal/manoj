{% extends 'base.twig' %}

{% block title %}Advanced Game Search{% endblock %}

{% set current_page = 'search' %}

{% block scripts %}
<script>
function performSearch() {
    const formData = {
        title: document.getElementById('gameTitle').value,
        genre: document.getElementById('genre').value,
        platform: document.getElementById('platform').value,
        min_rating: document.getElementById('minRating').value,
        max_rating: document.getElementById('maxRating').value,
        min_price: document.getElementById('minPrice').value,
        max_price: document.getElementById('maxPrice').value,
        completion_filter: document.getElementById('completionFilter').value,
        is_multiplayer: document.getElementById('multiplayer').checked ? '1' : '',
        has_dlc: document.getElementById('hasDlc').checked ? '1' : '',
        is_digital: document.getElementById('digital').checked ? '1' : '',
        sort_by: document.getElementById('sortBy').value
    };
    
    const resultsContainer = document.getElementById('resultsContainer');
    const resultCount = document.getElementById('resultCount');
    resultsContainer.innerHTML = '<div class="text-center py-5"><div class="spinner-border text-primary"></div><p class="mt-3">Searching your game library...</p></div>';
    
    fetch('ajax_search.php', {
        method: 'POST',
        headers: {'Content-Type': 'application/json'},
        body: JSON.stringify(formData)
    })
    .then(response => {
        if (!response.ok) {
            throw new Error('Network response was not ok');
        }
        return response.json();
    })
    .then(data => {
        if (data.error) {
            resultsContainer.innerHTML = `<div class="alert alert-danger">${data.error}</div>`;
            return;
        }
        
        if (data.length === 0) {
            resultsContainer.innerHTML = `
                <div class="text-center py-5">
                    <i class="bi bi-search display-1 text-muted mb-3"></i>
                    <h4 class="text-muted">No games found</h4>
                    <p class="text-muted">Try adjusting your search criteria</p>
                </div>`;
            resultCount.textContent = '0';
            return;
        }
        
        resultCount.textContent = data.length;
        
        let html = '<div class="row">';
        data.forEach(game => {
            html += `
            <div class="col-md-6 mb-4">
                <div class="card h-100 game-card">
                    <div class="card-body">
                        <div class="d-flex justify-content-between align-items-start mb-3">
                            <h5 class="card-title mb-0">${game.title}</h5>
                            <span class="badge bg-primary">${game.genre || 'N/A'}</span>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <small class="text-muted">Platform</small>
                                <div><strong>${game.platform || 'N/A'}</strong></div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Year</small>
                                <div><strong>${game.release_year || 'N/A'}</strong></div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <small class="text-muted">Rating</small>
                                <div class="d-flex align-items-center">
                                    ${game.rating ? `
                                    <span class="me-2 fw-bold">${game.rating}/10</span>
                                    <div>
                                        ${Array.from({length: 5}, (_, i) => {
                                            if (game.rating >= (i+1)*2) {
                                                return '<i class="bi bi-star-fill text-warning"></i>';
                                            } else if (game.rating >= (i*2)+1) {
                                                return '<i class="bi bi-star-half text-warning"></i>';
                                            } else {
                                                return '<i class="bi bi-star text-warning"></i>';
                                            }
                                        }).join('')}
                                    </div>
                                    ` : '<span class="text-muted">Not rated</span>'}
                                </div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Price</small>
                                <div><strong>${game.price ? '£' + game.price : 'N/A'}</strong></div>
                            </div>
                        </div>
                        
                        <div class="row mb-3">
                            <div class="col-6">
                                <small class="text-muted">Playtime</small>
                                <div><strong>${game.playtime_hours ? game.playtime_hours + ' hrs' : 'N/A'}</strong></div>
                            </div>
                            <div class="col-6">
                                <small class="text-muted">Status</small>
                                <div>
                                    <span class="badge ${game.completion_status === 'Completed' ? 'bg-success' : 
                                                  game.completion_status === 'In Progress' ? 'bg-warning' : 
                                                  game.completion_status === 'Dropped' ? 'bg-danger' : 'bg-secondary'}">
                                        ${game.completion_status}
                                    </span>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <small class="text-muted">Features</small>
                            <div>
                                ${game.is_multiplayer ? '<span class="badge bg-info me-1">Multiplayer</span>' : ''}
                                ${game.has_dlc ? '<span class="badge bg-info me-1">Has DLC</span>' : ''}
                                ${game.is_digital ? '<span class="badge bg-info">Digital</span>' : ''}
                            </div>
                        </div>
                        
                        <div class="d-flex justify-content-between">
                            <a href="edit_game.php?id=${game.game_id}" class="btn btn-sm btn-outline-primary">
                                <i class="bi bi-pencil me-1"></i>Edit
                            </a>
                            <a href="delete_game.php?id=${game.game_id}" class="btn btn-sm btn-outline-danger" onclick="return confirm('Delete this game?')">
                                <i class="bi bi-trash me-1"></i>Delete
                            </a>
                            <span class="text-muted small">
                                <i class="bi bi-controller"></i> ID: ${game.game_id}
                            </span>
                        </div>
                    </div>
                </div>
            </div>`;
        });
        html += '</div>';
        resultsContainer.innerHTML = html;
    })
    .catch(error => {
        console.error('Search error:', error);
        resultsContainer.innerHTML = '<div class="alert alert-danger">Search error. Please try again.</div>';
    });
}

let searchTimeout;
document.getElementById('gameTitle').addEventListener('input', function() {
    clearTimeout(searchTimeout);
    searchTimeout = setTimeout(() => {
        if (this.value.length >= 2 || this.value.length === 0) {
            performSearch();
        }
    }, 500);
});

['genre', 'platform', 'minRating', 'maxRating', 'minPrice', 'maxPrice', 'completionFilter', 'sortBy'].forEach(id => {
    document.getElementById(id).addEventListener('change', performSearch);
});

['multiplayer', 'hasDlc', 'digital'].forEach(id => {
    document.getElementById(id).addEventListener('change', performSearch);
});

document.addEventListener('DOMContentLoaded', performSearch);

function resetSearch() {
    document.getElementById('searchForm').reset();
    setTimeout(performSearch, 100);
}
</script>
{% endblock %}

{% block content %}
<h2 class="mb-4">
    <i class="bi bi-search me-2"></i>Advanced Game Search
</h2>

<div class="card mb-4">
    <div class="card-body">
        <form id="searchForm">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Game Title</label>
                    <input type="text" id="gameTitle" class="form-control" placeholder="Search by title...">
                </div>
                <div class="col-md-3">
                    <label class="form-label">Genre</label>
                    <select id="genre" class="form-select">
                        <option value="">All Genres</option>
                        {% for genre in genres %}
                            <option value="{{ genre.genre }}">{{ genre.genre }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Platform</label>
                    <select id="platform" class="form-select">
                        <option value="">All Platforms</option>
                        {% for platform in platforms %}
                            <option value="{{ platform.platform }}">{{ platform.platform }}</option>
                        {% endfor %}
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" onclick="performSearch()" class="btn btn-primary w-100">
                        <i class="bi bi-search"></i>
                    </button>
                </div>
            </div>
            
            <div class="row g-3 mt-3">
                <div class="col-md-2">
                    <label class="form-label">Min Rating</label>
                    <input type="number" id="minRating" class="form-control" placeholder="0" min="0" max="10" step="0.1">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Rating</label>
                    <input type="number" id="maxRating" class="form-control" placeholder="10" min="0" max="10" step="0.1">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Min Price (£)</label>
                    <input type="number" step="0.01" id="minPrice" class="form-control" placeholder="Min £" min="0">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Max Price (£)</label>
                    <input type="number" step="0.01" id="maxPrice" class="form-control" placeholder="Max £" min="0">
                </div>
                <div class="col-md-2">
                    <label class="form-label">Status</label>
                    <select id="completionFilter" class="form-select">
                        <option value="">All Status</option>
                        <option value="Not Started">Not Started</option>
                        <option value="In Progress">In Progress</option>
                        <option value="Completed">Completed</option>
                        <option value="Dropped">Dropped</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Sort By</label>
                    <select id="sortBy" class="form-select">
                        <option value="title_asc">Title (A-Z)</option>
                        <option value="title_desc">Title (Z-A)</option>
                        <option value="rating_asc">Rating (Low-High)</option>
                        <option value="rating_desc">Rating (High-Low)</option>
                        <option value="price_asc">Price (Low-High)</option>
                        <option value="price_desc">Price (High-Low)</option>
                        <option value="playtime_desc">Playtime (High-Low)</option>
                        <option value="release_desc">Release (New-Old)</option>
                    </select>
                </div>
            </div>
            
            <div class="row g-3 mt-3">
                <div class="col-md-12">
                    <label class="form-label">Features</label>
                    <div class="d-flex flex-wrap gap-3">
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="multiplayer">
                            <label class="form-check-label" for="multiplayer">
                                <i class="bi bi-people me-1"></i>Multiplayer
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="hasDlc">
                            <label class="form-check-label" for="hasDlc">
                                <i class="bi bi-puzzle me-1"></i>Has DLC
                            </label>
                        </div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" id="digital">
                            <label class="form-check-label" for="digital">
                                <i class="bi bi-download me-1"></i>Digital
                            </label>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="row g-3 mt-3">
                <div class="col-md-2">
                    <label class="form-label">&nbsp;</label>
                    <button type="button" onclick="resetSearch()" class="btn btn-outline-light w-100">
                        <i class="bi bi-arrow-clockwise me-1"></i>Reset
                    </button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-header">
        <h5 class="mb-0">
            <i class="bi bi-list-ul me-2"></i>Search Results
            <span id="resultCount" class="badge bg-primary ms-2">0</span>
        </h5>
    </div>
    <div class="card-body">
        <div id="resultsContainer" class="mt-3">
            <p class="text-muted">Enter search criteria to see results</p>
        </div>
    </div>
</div>
{% endblock %}