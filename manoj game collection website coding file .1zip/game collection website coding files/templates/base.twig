<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}{{ site_name }}{% endblock %}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
       <style>
        :root {
            --primary-color: #1a237e;
            --secondary-color: #00bcd4;
            --accent-color: #ff5722;
            --dark-bg: #0a0a0a;
            --card-bg: #1a1a1a;
            --text-light: #ffffff;
            --text-muted: #b0b0b0;
            --border-color: #333333;
        }
        
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--dark-bg);
            color: var(--text-light);
            min-height: 100vh;
        }
        
        .navbar {
            background: rgba(26, 35, 126, 0.95) !important;
            backdrop-filter: blur(10px);
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.3);
            border-bottom: 3px solid var(--secondary-color);
        }
        
        .navbar-brand {
            font-weight: 800;
            font-size: 1.8rem;
            background: linear-gradient(45deg, var(--secondary-color), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            letter-spacing: 1px;
        }
        
        .nav-link {
            color: rgba(255, 255, 255, 0.85) !important;
            font-weight: 500;
            padding: 0.5rem 1rem;
            border-radius: 10px;
            transition: all 0.3s ease;
            position: relative;
            overflow: hidden;
        }
        
        .nav-link::before {
            content: '';
            position: absolute;
            bottom: 0;
            left: 50%;
            width: 0;
            height: 2px;
            background: var(--secondary-color);
            transition: all 0.3s ease;
            transform: translateX(-50%);
        }
        
        .nav-link:hover {
            color: white !important;
            transform: translateY(-2px);
        }
        
        .nav-link:hover::before {
            width: 80%;
        }
        
        .nav-link.active {
            color: white !important;
            background: rgba(0, 188, 212, 0.2);
        }
        
        .nav-link.active::before {
            width: 80%;
        }
        
        .badge {
            font-weight: 600;
            padding: 0.4em 0.8em;
            color: white;
        }
        
        .badge-genre {
            background: linear-gradient(135deg, #4a148c 0%, #7b1fa2 100%);
        }
        
        .badge-platform {
            background: linear-gradient(135deg, #006064 0%, #00838f 100%);
        }
        
        .badge-status {
            background: linear-gradient(135deg, #d84315 0%, #ff5722 100%);
        }
        
        .card {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            border-radius: 15px;
            overflow: hidden;
            transition: all 0.3s ease;
            color: var(--text-light);
        }
        
        .card:hover {
            transform: translateY(-10px);
            box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5);
            border-color: var(--secondary-color);
        }
        
        .card-header {
            background: linear-gradient(135deg, var(--primary-color) 0%, #283593 100%);
            color: white;
            border-bottom: 2px solid var(--secondary-color);
            font-weight: 700;
            letter-spacing: 0.5px;
        }
        
        footer {
            background: rgba(10, 10, 10, 0.95);
            border-top: 3px solid var(--secondary-color);
            backdrop-filter: blur(10px);
            margin-top: auto;
            color: var(--text-light);
        }
        
        .form-control, .form-select {
            background: rgba(255, 255, 255, 0.1);
            border: 1px solid var(--border-color);
            color: var(--text-light);
            border-radius: 10px;
            padding: 0.75rem;
            transition: all 0.3s ease;
        }
        
        .form-control:focus, .form-select:focus {
            background: rgba(255, 255, 255, 0.15);
            border-color: var(--secondary-color);
            box-shadow: 0 0 0 0.25rem rgba(0, 188, 212, 0.25);
            color: var(--text-light);
        }
        
        .form-control::placeholder {
            color: var(--text-muted);
        }
        
        .form-text, .form-label {
            color: var(--text-light);
        }
        
        .text-muted {
            color: var(--text-muted) !important;
        }
        
        .btn-primary {
            background: linear-gradient(135deg, var(--secondary-color) 0%, #0097a7 100%);
            border: none;
            font-weight: 600;
            padding: 0.75rem 1.5rem;
            border-radius: 10px;
            transition: all 0.3s ease;
            color: white;
        }
        
        .btn-primary:hover {
            background: linear-gradient(135deg, #0097a7 0%, var(--secondary-color) 100%);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(0, 188, 212, 0.3);
            color: white;
        }
        
        .btn-danger {
            background: linear-gradient(135deg, var(--accent-color) 0%, #d84315 100%);
            border: none;
            color: white;
        }
        
        .btn-danger:hover {
            background: linear-gradient(135deg, #d84315 0%, var(--accent-color) 100%);
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(255, 87, 34, 0.3);
            color: white;
        }
        
        .btn-outline-light {
            border: 2px solid var(--border-color);
            color: var(--text-light);
        }
        
        .btn-outline-light:hover {
            background: rgba(255, 255, 255, 0.1);
            border-color: var(--secondary-color);
            transform: translateY(-3px);
            color: var(--text-light);
        }
        
        .table {
            color: var(--text-light);
            background: var(--card-bg);
        }
        
        .table th {
            background: rgba(26, 35, 126, 0.7);
            border-bottom: 2px solid var(--secondary-color);
            font-weight: 600;
            padding: 1rem;
            color: white;
        }
        
        .table td {
            padding: 1rem;
            border-color: var(--border-color);
            vertical-align: middle;
            background: var(--card-bg);
        }
        
        .table tbody tr {
            transition: all 0.3s ease;
            border-color: var(--border-color);
        }
        
        .table tbody tr:hover {
            background: rgba(0, 188, 212, 0.1);
            transform: scale(1.01);
        }
        
        .spinner-border {
            width: 1.2rem;
            height: 1.2rem;
            border-width: 0.2em;
        }
        
        .alert {
            border-radius: 10px;
            border: none;
            backdrop-filter: blur(10px);
            color: white;
        }
        
        .alert-info {
            background: linear-gradient(135deg, rgba(0, 188, 212, 0.2) 0%, rgba(0, 188, 212, 0.3) 100%);
            border-left: 4px solid var(--secondary-color);
        }
        
        .alert-danger {
            background: linear-gradient(135deg, rgba(255, 82, 82, 0.2) 0%, rgba(211, 47, 47, 0.3) 100%);
            border-left: 4px solid var(--accent-color);
        }
        
        .alert-success {
            background: linear-gradient(135deg, rgba(76, 175, 80, 0.2) 0%, rgba(46, 125, 50, 0.3) 100%);
            border-left: 4px solid #4CAF50;
        }
        
        .game-stats-card {
            background: linear-gradient(135deg, rgba(26, 35, 126, 0.8) 0%, rgba(38, 50, 56, 0.8) 100%);
            border-radius: 15px;
            padding: 1.5rem;
            border: 1px solid rgba(0, 188, 212, 0.3);
            color: white;
        }
        
        .stat-icon {
            font-size: 2.5rem;
            color: var(--secondary-color);
            margin-bottom: 1rem;
        }
        
        .stat-value {
            font-size: 2.2rem;
            font-weight: 800;
            background: linear-gradient(45deg, var(--secondary-color), #fff);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            line-height: 1;
        }
        
        .stat-label {
            color: rgba(255, 255, 255, 0.7);
            font-size: 0.9rem;
            text-transform: uppercase;
            letter-spacing: 1px;
        }
        
        .rating-star {
            color: #ffd700;
            font-size: 1.2rem;
            text-shadow: 0 0 10px rgba(255, 215, 0, 0.5);
        }
        
        .completion-badge {
            padding: 0.3em 0.8em;
            border-radius: 20px;
            font-weight: 600;
            font-size: 0.85rem;
            color: white;
        }
        
        .completed { background: linear-gradient(135deg, #2e7d32 0%, #4caf50 100%); }
        .in-progress { background: linear-gradient(135deg, #f57c00 0%, #ff9800 100%); }
        .not-started { background: linear-gradient(135deg, #616161 0%, #9e9e9e 100%); }
        .dropped { background: linear-gradient(135deg, #c62828 0%, #f44336 100%); }
        
        .main-content {
            min-height: calc(100vh - 200px);
        }
        
        .user-greeting {
            background: linear-gradient(45deg, var(--secondary-color), var(--primary-color));
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            font-weight: 700;
            font-size: 1.1rem;
        }
        
        .logout-btn {
            background: linear-gradient(135deg, var(--accent-color) 0%, #c62828 100%);
            color: white;
            border: none;
            padding: 0.5rem 1rem;
            border-radius: 10px;
            font-weight: 600;
            transition: all 0.3s ease;
        }
        
        .logout-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(255, 87, 34, 0.3);
            color: white;
        }
        
        .breadcrumb {
            background: var(--card-bg);
            border-radius: 10px;
            padding: 1rem;
        }
        
        .breadcrumb-item a {
            color: var(--secondary-color);
            text-decoration: none;
        }
        
        .breadcrumb-item.active {
            color: var(--text-light);
        }
        
        .list-group-item {
            background: transparent;
            border-color: var(--border-color);
            color: var(--text-light);
        }
        
        .progress {
            background: rgba(255, 255, 255, 0.1);
            border-radius: 10px;
        }
        
        .progress-bar {
            border-radius: 10px;
        }
        
        .small {
            color: var(--text-muted);
        }
        
        h1, h2, h3, h4, h5, h6 {
            color: var(--text-light);
        }
        
        p {
            color: var(--text-light);
        }
        
        .text-dark {
            color: var(--text-light) !important;
        }
        
        .list-group {
            background: var(--card-bg);
        }
        
        .dropdown-menu {
            background: var(--card-bg);
            border: 1px solid var(--border-color);
            color: var(--text-light);
        }
        
        .dropdown-item {
            color: var(--text-light);
        }
        
        .dropdown-item:hover {
            background: rgba(0, 188, 212, 0.2);
            color: var(--text-light);
        }
        
        .modal-content {
            background: var(--card-bg);
            color: var(--text-light);
            border: 1px solid var(--border-color);
        }
        
        .modal-header {
            border-bottom: 1px solid var(--border-color);
        }
        
        .modal-footer {
            border-top: 1px solid var(--border-color);
        }
        
        .close {
            color: var(--text-light);
        }
        
        .bg-light {
            background-color: var(--card-bg) !important;
        }
        
        .bg-white {
            background-color: var(--card-bg) !important;
        }
    </style>
</head>
<body class="d-flex flex-column min-vh-100">
    {% if username %}
    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center" href="index.php">
                <i class="bi bi-controller me-2"></i>
                {{ site_name }}
            </a>
            
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav ms-auto align-items-center">
                    <li class="nav-item me-3">
                        <span class="user-greeting">
                            <i class="bi bi-person-circle me-2"></i>
                            {{ username }}
                        </span>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ current_page == 'index' ? 'active' : '' }}" href="index.php">
                            <i class="bi bi-house-door me-1"></i>
                            Dashboard
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link {{ current_page == 'search' ? 'active' : '' }}" href="search.php">
                            <i class="bi bi-search me-1"></i>
                            Advanced Search
                        </a>
                    </li>
                    <li class="nav-item ms-2">
                        <a class="logout-btn" href="logout.php">
                            <i class="bi bi-box-arrow-right me-1"></i>
                            Logout
                        </a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
    {% endif %}

    <main class="flex-grow-1 py-4 main-content">
        <div class="container">
            {% block content %}{% endblock %}
        </div>
    </main>

    <footer class="py-4 mt-auto">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-md-6">
                    <h5 class="mb-2">
                        <i class="bi bi-controller me-2" style="color: var(--secondary-color);"></i>
                        {{ site_name }}
                    </h5>
                    <p class="mb-0">
                        <i class="bi bi-person-badge me-1"></i>
                        {{ author }} ({{ student_id }})
                    </p>
                </div>
                <div class="col-md-6 text-md-end">
                    <p class="mb-0">
                        <i class="bi bi-copyright me-1"></i>
                        {{ current_year }} - Game Collection System
                    </p>
                    <small class="text-light opacity-75">
                        <i class="bi bi-shield-check me-1"></i>
                        Secure Game Database Management
                    </small>
                </div>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    {% block scripts %}{% endblock %}
</body>
</html>