{% extends 'base.twig' %}

{% block title %}Game Collection Dashboard{% endblock %}

{% set current_page = 'index' %}

{% block content %}
<div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-2">
                <i class="bi bi-controller text-primary me-2"></i>
                My Game Collection
            </h1>
            <p class="text-muted mb-0">Manage your gaming journey and track your progress</p>
        </div>
        <a href="add_game.php" class="btn btn-primary">
            <i class="bi bi-plus-circle me-2"></i>Add New Game
        </a>
    </div>
</div>

<div class="row mb-4">
    <div class="col-md-3 mb-3">
        <div class="game-stats-card">
            <div class="stat-icon">
                <i class="bi bi-collection-play"></i>
            </div>
            <div class="stat-value">{{ total_games }}</div>
            <div class="stat-label">Total Games</div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="game-stats-card">
            <div class="stat-icon">
                <i class="bi bi-clock-history"></i>
            </div>
            <div class="stat-value">{{ total_playtime|round(1) }}</div>
            <div class="stat-label">Total Playtime (hrs)</div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="game-stats-card">
            <div class="stat-icon">
                <i class="bi bi-star"></i>
            </div>
            <div class="stat-value">{{ avg_rating }}</div>
            <div class="stat-label">Average Rating</div>
        </div>
    </div>
    <div class="col-md-3 mb-3">
        <div class="game-stats-card">
            <div class="stat-icon">
                <i class="bi bi-trophy"></i>
            </div>
            <div class="stat-value">
                {% for stat in stats %}
                    {% if stat.completion_status == 'Completed' %}
                        {{ stat.count }}
                    {% endif %}
                {% endfor %}
            </div>
            <div class="stat-label">Games Completed</div>
        </div>
    </div>
</div>

<div class="card mb-4">
    <div class="card-header">
		<i class="bi bi-funnel me-2"></i>Filter Games
	</div>
    <div class="card-body">
        <form method="GET" class="row g-3">
            <div class="col-md-3">
                <label class="form-label">Search</label>
                <input type="text" name="search" class="form-control" placeholder="Title, developer, publisher..." value="{{ search }}">
            </div>
            <div class="col-md-2">
                <label class="form-label">Genre</label>
                <select name="genre" class="form-select">
                    <option value="">All Genres</option>
                    {% for genre in genres %}
                        <option value="{{ genre.genre }}" {{ genre.genre == genre_filter ? 'selected' : '' }}>
                            {{ genre.genre }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Platform</label>
                <select name="platform_filter" class="form-select">
                    <option value="">All Platforms</option>
                    {% for platform in platforms %}
                        <option value="{{ platform.platform }}" {{ platform.platform == platform_filter ? 'selected' : '' }}>
                            {{ platform.platform }}
                        </option>
                    {% endfor %}
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">Status</label>
                <select name="completion_filter" class="form-select">
                    <option value="">All Status</option>
                    <option value="Not Started" {{ completion_filter == 'Not Started' ? 'selected' : '' }}>Not Started</option>
                    <option value="In Progress" {{ completion_filter == 'In Progress' ? 'selected' : '' }}>In Progress</option>
                    <option value="Completed" {{ completion_filter == 'Completed' ? 'selected' : '' }}>Completed</option>
                    <option value="Dropped" {{ completion_filter == 'Dropped' ? 'selected' : '' }}>Dropped</option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label">&nbsp;</label>
                <button type="submit" class="btn btn-primary w-100">
                    <i class="bi bi-filter me-1"></i>Filter
                </button>
            </div>
            <div class="col-md-1">
                <label class="form-label">&nbsp;</label>
                <a href="index.php" class="btn btn-outline-light w-100">
                    <i class="bi bi-x-circle"></i>
                </a>
            </div>
        </form>
    </div>
</div>

{% if games is empty %}
<div class="card">
    <div class="card-body text-center py-5">
        <i class="bi bi-controller display-1 text-muted mb-3"></i>
        <h3 class="text-muted">No games found</h3>
        <p class="text-muted mb-4">Start building your game collection</p>
        <a href="add_game.php" class="btn btn-primary btn-lg">
            <i class="bi bi-plus-circle me-2"></i>Add Your First Game
        </a>
    </div>
</div>
{% else %}
<div class="table-responsive">
    <table class="table table-dark table-hover">
        <thead>
            <tr>
                <th>ID</th>
                <th>Title</th>
                <th>Genre</th>
                <th>Platform</th>
                <th>Rating</th>
                <th>Playtime</th>
                <th>Status</th>
                <th>Price</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            {% for game in games %}
            <tr>
                <td>{{ game.game_id }}</td>
                <td>
                    <div class="fw-bold">{{ game.title }}</div>
                    <small class="text-muted">
                        {{ game.developer }}
                        {% if game.release_year %}
                            ({{ game.release_year }})
                        {% endif %}
                    </small>
                </td>
                <td>
                    <span class="badge badge-genre">{{ game.genre }}</span>
                </td>
                <td>
                    <span class="badge badge-platform">{{ game.platform }}</span>
                </td>
                <td>
                    {% if game.rating %}
                    <div class="d-flex align-items-center">
                        <span class="me-2">{{ game.rating }}/10</span>
                        <div>
                            {% for i in 1..5 %}
                                {% if game.rating >= i*2 %}
                                    <i class="bi bi-star-fill rating-star"></i>
                                {% elseif game.rating >= (i*2)-1 %}
                                    <i class="bi bi-star-half rating-star"></i>
                                {% else %}
                                    <i class="bi bi-star rating-star"></i>
                                {% endif %}
                            {% endfor %}
                        </div>
                    </div>
                    {% else %}
                    <span class="text-muted">Not rated</span>
                    {% endif %}
                </td>
                <td>
                    {% if game.playtime_hours %}
                    <div class="d-flex align-items-center">
                        <i class="bi bi-clock me-2"></i>
                        {{ game.playtime_hours }} hrs
                    </div>
                    {% else %}
                    <span class="text-muted">-</span>
                    {% endif %}
                </td>
                <td>
                    <span class="completion-badge {{ game.completion_status|lower|replace({' ': '-'}) }}">
                        {{ game.completion_status }}
                    </span>
                </td>
                <td>
                    {% if game.price %}
                    <span class="fw-bold">£{{ game.price }}</span>
                    {% else %}
                    <span class="text-muted">-</span>
                    {% endif %}
                </td>
                <td>
                    <div class="btn-group btn-group-sm">
                        <a href="edit_game.php?id={{ game.game_id }}" class="btn btn-outline-light">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="delete_game.php?id={{ game.game_id }}" class="btn btn-outline-danger" onclick="return confirm('Delete {{ game.title }}?')">
                            <i class="bi bi-trash"></i>
                        </a>
                        <a href="game_details.php?id={{ game.game_id }}" class="btn btn-outline-info">
                            <i class="bi bi-eye"></i>
                        </a>
                    </div>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>
<div class="mt-4">
    <div class="alert alert-info">
        <i class="bi bi-info-circle me-2"></i>
        Showing {{ total_games }} game{{ total_games != 1 ? 's' : '' }}
        {% if search or genre_filter or platform_filter or completion_filter %}
        (filtered results)
        {% endif %}
    </div>
</div>
{% endif %}
{% endblock %}